rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }
    function userDocExists() { return exists(userPath(uid())); }
    function userDoc() { return get(userPath(uid())).data; }
    function role() {
      return userDocExists() ? userDoc().get('role', '') : '';
    }
    function isActive() {
      return userDocExists() && userDoc().get('isActive', true) == true;
    }
    function isManagerRole() { return role() == 'manager'; }
    function isHRRole() { return role() == 'hr_admin'; }
    function isSuperAdmin() { return role() == 'super_admin'; }
    function isHR() { return isHRRole() || isSuperAdmin(); }
    function isManagerOrAbove() {
      return isManagerRole() || isHRRole() || isSuperAdmin();
    }
    function canReviewSuggestions() {
      return isManagerRole() || isSuperAdmin();
    }
    function isOwner(docUserId) { return uid() == docUserId; }
    function isMyManager(managerId) { return managerId is string && uid() == managerId; }
    function isAssignedManagerFor(userData) {
      return isManagerRole()
        && (
          userData.get('managerId', '') == uid()
          || uid() in userData.get('managerIds', [])
        );
    }
    function isAssignedManagerForUser(userId) {
      return isAssignedManagerFor(recipientDoc(userId));
    }
    function recipientDoc(userId) {
      return get(userPath(userId)).data;
    }
    function myManagerId() {
      return userDoc().get('managerId', '') == null ? '' : userDoc().get('managerId', '');
    }
    function requestManagerId() {
      return request.resource.data.get('managerId', '') == null
        ? ''
        : request.resource.data.get('managerId', '');
    }
    function validRequestManagerId() {
      return requestManagerId() == myManagerId();
    }
    function isValidSelfCreate() {
      return request.resource.data.userId == uid()
        && request.resource.data.employeeId == userDoc().get('employeeId', '')
        && request.resource.data.employeeName == userDoc().get('displayName', '')
        && request.resource.data.locationId == userDoc().get('locationId', '')
        && validRequestManagerId();
    }
    function notificationKeysAreValid() {
      return request.resource.data.keys().hasOnly([
        'notificationId', 'type', 'title', 'body', 'data', 'isRead', 'createdAt'
      ])
      && request.resource.data.notificationId is string
      && request.resource.data.type is string
      && request.resource.data.title is string
      && request.resource.data.body is string
      && request.resource.data.isRead == false;
    }
    function canCreateNotificationFor(userId) {
      return uid() == userId
        || isHR()
        || (
          isManagerRole()
          && (
            recipientDoc(userId).get('managerId', '') == uid()
            || uid() in recipientDoc(userId).get('managerIds', [])
          )
        )
        || userDoc().get('managerId', '') == userId
        || userId in userDoc().get('managerIds', [])
        || (
          request.resource.data.type in [
            'salary_deduction_pending',
            'permission_pending_hr',
            'advance_pending_hr',
            'leave_request_submitted',
            'complaint_new',
            'attendance_security_review'
          ]
          && recipientDoc(userId).get('role', '') in ['hr_admin', 'super_admin']
        )
        || (
          request.resource.data.type in [
            'permission_pending_manager',
            'advance_pending_manager',
            'leave_request_submitted'
          ]
          && (
            userDoc().get('managerId', '') == userId
            || userId in userDoc().get('managerIds', [])
          )
        )
        || (
          request.resource.data.type == 'suggestion_new'
          && recipientDoc(userId).get('role', '') in ['manager', 'super_admin']
        )
        || (
          request.resource.data.type in [
            'task_assigned', 'task_reviewed', 'task_overdue'
          ]
          && (
            uid() == userId ||
            isHR() ||
            (
              isManagerRole()
              && (
                recipientDoc(userId).get('managerId', '') == uid()
                || uid() in recipientDoc(userId).get('managerIds', [])
              )
            )
          )
        )
        || (
          request.resource.data.type in ['kpi_assigned', 'kpi_progress_updated']
          && (
            uid() == userId ||
            isHR() ||
            (
              isManagerRole()
              && (
                recipientDoc(userId).get('managerId', '') == uid()
                || uid() in recipientDoc(userId).get('managerIds', [])
              )
            )
          )
        )
        || (
          request.resource.data.type == 'warning_reward_created'
          && (
            isHR() ||
            (
              isManagerRole()
              && (
                recipientDoc(userId).get('managerId', '') == uid()
                || uid() in recipientDoc(userId).get('managerIds', [])
              )
            )
          )
        );
    }
    function canIncrementUnreadOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['unreadNotifications'])
        && request.resource.data.unreadNotifications ==
          resource.data.get('unreadNotifications', 0) + 1;
    }
    function ownerProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['passwordChangedAt', 'photoURL', 'notificationTokens', 'updatedAt']);
    }
    function ownerAttendanceDeviceBind() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'registeredAttendanceDeviceId',
          'registeredAttendanceDeviceLabel',
          'registeredAttendanceDeviceAt'
        ])
        && resource.data.get('registeredAttendanceDeviceId', '') == ''
        && request.resource.data.get('registeredAttendanceDeviceId', '') is string
        && request.resource.data.get('registeredAttendanceDeviceId', '').size() > 0
        && request.resource.data.get('registeredAttendanceDeviceLabel', '') is string;
    }
    function ownerAttendanceDeviceLegacyMigration() {
      let oldDeviceId = resource.data.get('registeredAttendanceDeviceId', '');
      let newDeviceId = request.resource.data.get('registeredAttendanceDeviceId', '');
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'registeredAttendanceDeviceId',
          'registeredAttendanceDeviceLabel',
          'registeredAttendanceDeviceAt'
        ])
        && oldDeviceId is string
        && oldDeviceId.size() > 0
        && !oldDeviceId.matches('.*-install-.*')
        && newDeviceId is string
        && newDeviceId.matches('.*-install-.*')
        && request.resource.data.get('registeredAttendanceDeviceLabel', '') is string;
    }
    function managerBalanceUpdate() {
      return isManagerRole()
        && (
          resource.data.get('managerId', '') == uid() ||
          uid() in resource.data.get('managerIds', [])
        )
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'permissionBalance',
            'permissionBalance.usedThisMonth',
            'permissionBalance.usedHoursThisMonth',
            'permissionBalance.lastResetMonth',
            'updatedAt'
          ]);
    }
    function employeeQuotaReset(userId) {
      return isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'permissionBalance',
            'permissionBalance.usedThisMonth',
            'permissionBalance.usedHoursThisMonth',
            'permissionBalance.lastResetMonth',
            'updatedAt'
          ])
        && request.resource.data.permissionBalance.usedThisMonth == 0
        && request.resource.data.permissionBalance.usedHoursThisMonth == 0.0;
    }
    function hrCanWriteUser() {
      return isHRRole()
        && resource.data.get('role', '') != 'super_admin'
        && request.resource.data.get('role', '') in ['employee', 'manager']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'employeeId', 'department', 'position', 'role',
          'locationId', 'locationName', 'baseMonthlySalary', 'salaryCurrency',
          'leaveBalance', 'leaveBalance.daysOff',
          'managerId', 'managerName', 'managerIds', 'managerNames',
          'managerCodes', 'isActive', 'workSchedule', 'updatedAt',
          'registeredAttendanceDeviceId',
          'registeredAttendanceDeviceLabel',
          'registeredAttendanceDeviceAt'
        ]);
    }
    function hrCanCreateUser() {
      return isHRRole()
        && request.resource.data.get('role', '') in ['employee', 'manager']
        && request.resource.data.keys().hasOnly([
          'email', 'displayName', 'photoURL', 'role', 'employeeId',
          'department', 'position', 'locationId', 'locationName',
          'baseMonthlySalary', 'salaryCurrency', 'managerId', 'managerName',
          'managerIds', 'managerNames', 'managerCodes', 'isActive',
          'joinDate', 'workSchedule', 'leaveBalance', 'permissionBalance',
          'notificationTokens', 'unreadNotifications', 'createdAt',
          'updatedAt', 'passwordChangedAt'
        ]);
    }
    function attendanceCreateKeys() {
      return request.resource.data.keys().hasOnly([
        'userId', 'employeeId', 'employeeName', 'locationId', 'locationName',
        'managerId', 'date', 'checkInTime', 'checkInLocation',
        'localCheckInTime', 'isWithinGeofence', 'isLate', 'lateMinutes',
        'salaryDeductionFraction', 'salaryDeductionAmount',
        'salaryCurrency', 'salaryDeductionCode', 'salaryDeductionLabel',
        'salaryDeductionApprovalStatus',
        'deviceId', 'deviceLabel', 'biometricVerified', 'status',
        'offlineCaptured', 'offlineCapturedAt', 'offlineDistanceMeters',
        'offlineAllowedRadiusMeters', 'offlineAccuracyMeters',
        'securityReviewStatus', 'securityReviewedBy', 'securityReviewedAt',
        'locationRiskLevel', 'locationRiskReasons', 'locationRiskMessage',
        'locationAccuracyMeters', 'locationDistanceMeters',
        'locationAllowedRadiusMeters', 'locationMocked',
        'locationCapturedOffline'
      ]);
    }
    function attendanceCreateValues() {
      return request.resource.data.status in [
        'present', 'late', 'late_quarter_day', 'late_half_day', 'late_full_day'
      ]
      && request.resource.data.isWithinGeofence == true
      && request.resource.data.biometricVerified == true
      && request.resource.data.get('locationMocked', false) == false
      && request.resource.data.get('securityReviewStatus', 'none') in ['none', 'pending_hr']
      && request.resource.data.get('locationRiskLevel', 'low') in ['low', 'medium', 'high']
      && request.resource.data.get('locationAccuracyMeters', 0) >= 0
      && request.resource.data.get('locationDistanceMeters', 0) >= 0
      && request.resource.data.get('locationAllowedRadiusMeters', 0) >= 0
      && request.resource.data.salaryDeductionApprovalStatus in ['none', 'pending_hr']
      && request.resource.data.salaryDeductionFraction >= 0
      && request.resource.data.salaryDeductionFraction <= 1
      && request.resource.data.salaryDeductionAmount >= 0
      && request.resource.data.lateMinutes >= 0;
    }
    function attendanceOwnerCheckoutKeys() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'checkOutTime','localCheckOutTime','checkOutLocation',
          'totalWorkHours', 'checkOutDeviceId', 'checkOutDeviceLabel',
          'checkOutBiometricVerified',
          'salaryDeductionFraction', 'salaryDeductionAmount',
          'salaryCurrency', 'salaryDeductionCode', 'salaryDeductionLabel',
          'salaryDeductionApprovalStatus', 'salaryDeductionDetectedAt',
          'offlineCheckoutCaptured', 'offlineCheckoutCapturedAt',
          'offlineCheckoutDistanceMeters',
          'offlineCheckoutAllowedRadiusMeters', 'offlineCheckoutAccuracyMeters',
          'checkoutSecurityReviewStatus',
          'checkoutLocationRiskLevel', 'checkoutLocationRiskReasons',
          'checkoutLocationRiskMessage', 'checkoutLocationAccuracyMeters',
          'checkoutLocationDistanceMeters',
          'checkoutLocationAllowedRadiusMeters', 'checkoutLocationMocked',
          'checkoutLocationCapturedOffline'
        ]);
    }
    function attendanceOwnerCheckoutValues() {
      return (
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['checkOutBiometricVerified'])
          || request.resource.data.checkOutBiometricVerified == true
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['totalWorkHours'])
          || request.resource.data.totalWorkHours >= 0
        )
        && request.resource.data.get('checkoutLocationMocked', false) == false
        && request.resource.data.get('checkoutSecurityReviewStatus', 'none') in ['none', 'pending_hr']
        && request.resource.data.get('checkoutLocationRiskLevel', 'low') in ['low', 'medium', 'high']
        && request.resource.data.get('checkoutLocationAccuracyMeters', 0) >= 0
        && request.resource.data.get('checkoutLocationDistanceMeters', 0) >= 0
        && request.resource.data.get('checkoutLocationAllowedRadiusMeters', 0) >= 0
        && request.resource.data.salaryDeductionFraction >= 0
        && request.resource.data.salaryDeductionFraction <= 1
        && request.resource.data.salaryDeductionAmount >= 0
        && request.resource.data.salaryDeductionApprovalStatus in [
          'none', 'pending_hr', 'approved', 'rejected'
        ];
    }
    function attendanceOwnerCheckInReplacement() {
      return isOwner(resource.data.userId)
        && resource.data.get('checkInTime', null) == null
        && request.resource.data.userId == uid()
        && request.resource.data.date == resource.data.date
        && request.resource.data.employeeId == userDoc().get('employeeId', '')
        && request.resource.data.employeeName == userDoc().get('displayName', '')
        && request.resource.data.locationId == userDoc().get('locationId', '')
        && validRequestManagerId()
        && attendanceCreateKeys()
        && attendanceCreateValues();
    }
    function attendanceHrDeductionReview() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'salaryDeductionApprovalStatus',
          'salaryDeductionReviewedBy',
          'salaryDeductionReviewedAt'
        ])
        && resource.data.salaryDeductionApprovalStatus == 'pending_hr'
        && request.resource.data.salaryDeductionApprovalStatus in ['approved', 'rejected']
        && request.resource.data.salaryDeductionReviewedBy == uid();
    }
    function attendanceHrSecurityReview() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'securityReviewStatus',
          'securityReviewedBy',
          'securityReviewedAt',
          'checkoutSecurityReviewStatus',
          'checkoutSecurityReviewedBy',
          'checkoutSecurityReviewedAt'
        ])
        && (
          (
            resource.data.get('securityReviewStatus', 'none') == 'pending_hr'
            && request.resource.data.get('securityReviewStatus', 'none') in ['approved', 'rejected']
            && request.resource.data.get('securityReviewedBy', '') == uid()
          )
          ||
          (
            resource.data.get('checkoutSecurityReviewStatus', 'none') == 'pending_hr'
            && request.resource.data.get('checkoutSecurityReviewStatus', 'none') in ['approved', 'rejected']
            && request.resource.data.get('checkoutSecurityReviewedBy', '') == uid()
          )
        );
    }
    function leaveHrReview() {
      return isHR()
        && resource.data.status == 'pending_hr'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'status', 'reviewedBy', 'reviewedAt', 'reviewerComment', 'isRead',
            'managerId', 'managerName', 'managerApprovalIndex'
          ])
        && request.resource.data.status in ['pending_manager', 'approved', 'rejected']
        && request.resource.data.reviewedBy == uid();
    }
    function leaveManagerReview() {
      return (
          (isManagerRole() && isMyManager(resource.data.managerId)) ||
          isSuperAdmin()
        )
        && resource.data.status == 'pending_manager'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'status', 'reviewedBy', 'reviewedAt', 'reviewerComment', 'isRead',
            'managerId', 'managerName', 'managerApprovalIndex', 'managerApprovalTrail'
          ])
        && request.resource.data.status in ['pending_manager', 'approved', 'rejected']
        && request.resource.data.reviewedBy == uid();
    }
    function advanceHrReview() {
      return isHR()
        && resource.data.status == 'pending_hr'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'status', 'reviewedBy', 'reviewedAt', 'reviewerComment', 'isRead',
            'managerId', 'managerName', 'managerApprovalIndex'
          ])
        && request.resource.data.status in ['pending_manager', 'approved', 'rejected']
        && request.resource.data.reviewedBy == uid();
    }
    function advanceManagerReview() {
      return (
          (isManagerRole() && isMyManager(resource.data.managerId)) ||
          isSuperAdmin()
        )
        && resource.data.status == 'pending_manager'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'status', 'reviewedBy', 'reviewedAt', 'reviewerComment', 'isRead',
            'managerId', 'managerName', 'managerApprovalIndex', 'managerApprovalTrail'
          ])
        && request.resource.data.status in ['pending_manager', 'approved', 'rejected']
        && request.resource.data.reviewedBy == uid();
    }
    function permissionHrReview() {
      return isHR()
        && resource.data.status == 'pending_hr'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'status', 'reviewedBy', 'reviewedAt', 'reviewerComment', 'isRead',
            'hrReviewedBy', 'hrReviewedAt', 'hrReviewerComment',
            'managerId', 'managerName', 'managerApprovalIndex'
          ])
        && request.resource.data.status in ['pending_manager', 'approved', 'rejected']
        && request.resource.data.reviewedBy == uid()
        && request.resource.data.hrReviewedBy == uid();
    }
    function permissionManagerReview() {
      return (
          (isManagerRole() && isMyManager(resource.data.managerId)) ||
          isSuperAdmin()
        )
        && resource.data.status == 'pending_manager'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'status', 'reviewedBy', 'reviewedAt', 'reviewerComment', 'isRead',
            'managerReviewedBy', 'managerReviewedAt', 'managerReviewerComment',
            'managerId', 'managerName', 'managerApprovalIndex', 'managerApprovalTrail'
          ])
        && request.resource.data.status in ['pending_manager', 'approved', 'rejected']
        && request.resource.data.reviewedBy == uid()
        && request.resource.data.managerReviewedBy == uid();
    }
    function taskCreateKeys() {
      return request.resource.data.keys().hasOnly([
        'title', 'description', 'assigneeId', 'assigneeName',
        'assigneeEmployeeId', 'department', 'managerId', 'createdBy',
        'managerIds', 'createdByName', 'priority', 'status', 'dueDate',
        'createdAt', 'updatedAt', 'isRead'
      ]);
    }
    function taskCreateValues() {
      return request.resource.data.title is string
        && request.resource.data.title.size() >= 3
        && request.resource.data.assigneeId is string
        && request.resource.data.createdBy == uid()
        && request.resource.data.priority in ['low', 'medium', 'high', 'urgent']
        && request.resource.data.status == 'new'
        && request.resource.data.isRead == false
        && (
          isHR() ||
          (
            isManagerRole()
            && uid() in request.resource.data.get('managerIds', [])
            && (
              recipientDoc(request.resource.data.assigneeId).get('managerId', '') == uid()
              || uid() in recipientDoc(request.resource.data.assigneeId).get('managerIds', [])
            )
          )
        );
    }
    function taskOwnerStatusUpdate() {
      return isOwner(resource.data.assigneeId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'isRead', 'updatedAt', 'completedAt', 'attachmentUrl'])
        && request.resource.data.status in ['in_progress', 'done']
        && request.resource.data.isRead == true;
    }
    function taskReviewerUpdate() {
      return (
          isHR() ||
          (
            isManagerRole()
            && (
              resource.data.managerId == uid()
              || uid() in resource.data.get('managerIds', [])
            )
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'status', 'qualityScore', 'managerComment', 'updatedAt'
          ])
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'updatedAt'])
            && request.resource.data.status == 'cancelled'
          )
          ||
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['qualityScore', 'managerComment', 'updatedAt'])
            && resource.data.status == 'done'
            && request.resource.data.qualityScore >= 0
            && request.resource.data.qualityScore <= 100
          )
        );
    }
    function kpiTemplateCreateKeys() {
      return request.resource.data.keys().hasOnly([
        'title', 'department', 'createdBy', 'createdByName',
        'isActive', 'metrics', 'createdAt'
      ]);
    }
    function employeeKpiCreateKeys() {
      return request.resource.data.keys().hasOnly([
        'templateId', 'userId', 'employeeId', 'employeeName',
        'department', 'managerId', 'managerIds', 'monthKey', 'status', 'metrics',
        'overallProgress', 'createdBy', 'createdAt', 'updatedAt'
      ]);
    }
    function canManageEmployeeKpiFor(userId, managerId) {
      return isHR()
        || (
          isManagerRole()
          && (
            managerId == uid()
            || uid() in recipientDoc(userId).get('managerIds', [])
          )
          && (
            recipientDoc(userId).get('managerId', '') == uid()
            || uid() in recipientDoc(userId).get('managerIds', [])
          )
        );
    }
    function employeeKpiCreateValues() {
      return request.resource.data.userId is string
        && request.resource.data.monthKey is string
        && request.resource.data.status == 'active'
        && request.resource.data.overallProgress == 0
        && request.resource.data.createdBy == uid()
        && canManageEmployeeKpiFor(
          request.resource.data.userId,
          request.resource.data.managerId
        );
    }
    function employeeKpiProgressUpdate() {
      return canManageEmployeeKpiFor(resource.data.userId, resource.data.managerId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['metrics', 'overallProgress', 'updatedAt'])
        && request.resource.data.overallProgress >= 0
        && request.resource.data.overallProgress <= 100;
    }
    function productivityScoreKeys() {
      return request.resource.data.keys().hasOnly([
        'userId', 'employeeId', 'employeeName', 'department', 'managerId',
        'monthKey', 'attendanceScore', 'punctualityScore',
        'taskCompletionScore', 'taskQualityScore', 'kpiScore',
        'overallScore', 'completedTasks', 'totalTasks', 'overdueTasks',
        'absentDays', 'lateDays', 'calculatedAt'
      ]);
    }
    function productivityScoreValues() {
      return request.resource.data.userId is string
        && request.resource.data.monthKey is string
        && request.resource.data.overallScore >= 0
        && request.resource.data.overallScore <= 100
        && canManageEmployeeKpiFor(
          request.resource.data.userId,
          request.resource.data.managerId
        );
    }
    function warningRewardKeys() {
      return request.resource.data.keys().hasOnly([
        'userId', 'employeeId', 'employeeName', 'department', 'managerId',
        'type', 'status', 'title', 'description', 'createdBy',
        'createdByName', 'source', 'monthKey', 'productivityScore',
        'amount', 'currency', 'createdAt', 'acknowledgedAt'
      ]);
    }
    function warningRewardCreateValues() {
      return request.resource.data.userId is string
        && request.resource.data.createdBy == uid()
        && request.resource.data.type in [
          'warning', 'reward', 'bonus_recommendation', 'follow_up'
        ]
        && request.resource.data.status in ['suggested', 'issued']
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 3
        && request.resource.data.get('amount', 0) >= 0
        && canManageEmployeeKpiFor(
          request.resource.data.userId,
          request.resource.data.managerId
        );
    }
    function warningRewardManagerUpdate() {
      return canManageEmployeeKpiFor(resource.data.userId, resource.data.managerId)
        && resource.data.status == 'suggested'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status'])
        && request.resource.data.status in ['issued', 'dismissed'];
    }
    function warningRewardOwnerAcknowledge() {
      return isOwner(resource.data.userId)
        && resource.data.status == 'issued'
        && request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'acknowledgedAt'])
        && request.resource.data.status == 'acknowledged';
    }
    function payrollRunKeys() {
      return request.resource.data.keys().hasOnly([
        'userId', 'employeeId', 'employeeName', 'department', 'managerId',
        'monthKey', 'currency', 'baseSalary', 'attendanceDeductions',
        'rewardsBonus', 'advances', 'netSalary', 'approvedDeductionCount',
        'bonusRecordCount', 'advanceRecordCount', 'status', 'calculatedAt',
        'calculatedBy', 'reviewedBy', 'reviewedAt'
      ]);
    }
    function payrollRunValues() {
      return request.resource.data.userId is string
        && request.resource.data.monthKey is string
        && request.resource.data.baseSalary >= 0
        && request.resource.data.attendanceDeductions >= 0
        && request.resource.data.rewardsBonus >= 0
        && request.resource.data.advances >= 0
        && request.resource.data.netSalary >= 0
        && request.resource.data.status in ['draft', 'reviewed', 'locked'];
    }

    match /companies/{companyId} {
      allow read: if isAuth() && isActive();
      allow write: if isAuth() && isActive() && isHR();
    }

    match /locations/{locationId} {
      allow read: if isAuth() && isActive();
      allow write: if isAuth() && isActive() && isHR();
    }

    match /companyDayOffs/{dayOffId} {
      allow read: if isAuth() && isActive();
      allow create, update: if isAuth() && isActive() && isHR()
        && request.resource.data.keys().hasOnly([
          'date', 'title', 'isActive', 'createdBy', 'createdAt'
        ]);
      allow delete: if isAuth() && isActive() && isHR();
    }

    match /notificationRecipients/{role} {
      allow read: if isAuth() && isActive();
      allow write: if isAuth() && isActive() && isHR()
        && role in ['hr_admin', 'manager', 'super_admin']
        && request.resource.data.keys().hasOnly(['role', 'userIds', 'updatedAt'])
        && request.resource.data.role == role
        && request.resource.data.userIds is list;
    }

    match /users/{userId} {
      allow read: if isAuth() && isActive() && (
        isOwner(userId) || isHR() || isAssignedManagerFor(resource.data)
      );
      allow update: if isAuth() && isActive() && (
        (isOwner(userId) && ownerProfileUpdate()) ||
        (isOwner(userId) && ownerAttendanceDeviceBind()) ||
        (isOwner(userId) && ownerAttendanceDeviceLegacyMigration()) ||
        (isOwner(userId) && employeeQuotaReset(userId)) ||
        managerBalanceUpdate() ||
        canIncrementUnreadOnly()
      );
      allow create: if isAuth() && isActive() && (
        isSuperAdmin() || hrCanCreateUser()
      );
      allow update: if isAuth() && isActive() && (
        isSuperAdmin() || hrCanWriteUser()
      );
      allow delete: if isAuth() && isActive() && (
        isSuperAdmin() || (isHRRole() && resource.data.get('role', '') != 'super_admin')
      );
    }

    match /attendanceDevices/{deviceId} {
      allow read: if isAuth() && isActive();
      allow create: if isAuth() && isActive()
        && !exists(/databases/$(database)/documents/attendanceDevices/$(deviceId))
        && request.resource.data.keys().hasOnly([
          'deviceId', 'userId', 'employeeId', 'employeeName',
          'deviceLabel', 'registeredAt'
        ])
        && request.resource.data.userId == uid()
        && request.resource.data.employeeId == userDoc().get('employeeId', '')
        && request.resource.data.employeeName == userDoc().get('displayName', '')
        && request.resource.data.deviceId is string
        && request.resource.data.deviceId.size() > 0
        && request.resource.data.deviceLabel is string;
      allow update: if false;
      allow delete: if isAuth() && isActive() && isHR();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuth() && isActive() && (
        isOwner(resource.data.userId) ||
        isMyManager(resource.data.managerId) ||
        isAssignedManagerForUser(resource.data.userId) ||
        isHR()
      );
      allow create: if isAuth() && isActive()
        && isValidSelfCreate()
        && attendanceCreateKeys()
        && attendanceCreateValues();
      allow update: if isAuth() && isActive() && (
        attendanceOwnerCheckInReplacement() ||
        (
          isOwner(resource.data.userId)
          && attendanceOwnerCheckoutKeys()
          && attendanceOwnerCheckoutValues()
        ) ||
        (isHR() && attendanceHrDeductionReview()) ||
        (isHR() && attendanceHrSecurityReview()) ||
        isSuperAdmin()
      );
      allow delete: if isAuth() && isActive() && isHR();
    }

    match /departments/{deptId} {
      allow read: if isAuth() && isActive();
      allow create, update, delete: if isAuth() && isActive() && isHR();
    }

    match /job_titles/{jobTitleId} {
      allow read: if isAuth() && isActive();
      allow create, update, delete: if isAuth() && isActive() && isHR();
    }

    match /leaves/{leaveId} {
      allow read: if isAuth() && isActive() && (
        isOwner(resource.data.userId) ||
        isMyManager(resource.data.managerId) ||
        uid() in resource.data.get('managerIds', []) ||
        isHR()
      );
      allow create: if isAuth() && isActive()
        && isValidSelfCreate()
        && request.resource.data.status == 'pending_hr'
        && request.resource.data.leaveType in ['annual', 'sick', 'casual', 'day_off']
        && request.resource.data.numberOfDays > 0
        && request.resource.data.keys().hasOnly([
          'userId', 'employeeId', 'employeeName', 'department', 'locationId',
          'managerId', 'leaveType', 'startDate', 'endDate', 'numberOfDays',
          'reason', 'attachmentUrl', 'status', 'submittedAt', 'isRead',
          'managerIds', 'managerNames', 'managerApprovalIndex',
          'managerApprovalTotal', 'managerApprovalTrail'
        ]);
      allow update: if isAuth() && isActive() && (
        (
          isOwner(resource.data.userId)
          && resource.data.status in ['pending', 'pending_hr', 'pending_manager']
          && request.resource.data.status == 'cancelled'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        ) ||
        leaveHrReview() ||
        leaveManagerReview() ||
        isSuperAdmin()
      );
      allow delete: if isAuth() && isActive() && isHR();
    }

    match /permissions/{permissionId} {
      allow read: if isAuth() && isActive() && (
        isOwner(resource.data.userId) ||
        isMyManager(resource.data.managerId) ||
        uid() in resource.data.get('managerIds', []) ||
        isHR()
      );
      allow create: if isAuth() && isActive()
        && isValidSelfCreate()
        && request.resource.data.status in ['pending_hr', 'invalid_late']
        && request.resource.data.permissionType in ['early_leave', 'late_arrival']
        && request.resource.data.durationMinutes > 0
        && request.resource.data.keys().hasOnly([
          'userId', 'employeeId', 'employeeName', 'department', 'locationId',
          'managerId', 'permissionType', 'requestDate', 'expectedTime',
          'durationMinutes', 'reason', 'status', 'isExceedingQuota',
          'isSubmittedAfterWorkStart', 'salaryDeductionFraction',
          'salaryDeductionAmount', 'salaryCurrency', 'salaryDeductionCode',
          'salaryDeductionLabel', 'monthKey', 'submittedAt', 'isRead',
          'managerIds', 'managerNames', 'managerApprovalIndex',
          'managerApprovalTotal', 'managerApprovalTrail'
        ]);
      allow update: if isAuth() && isActive() && (
        (
          isOwner(resource.data.userId)
          && resource.data.status in ['pending_hr', 'pending_manager']
          && request.resource.data.status == 'cancelled'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        ) ||
        permissionHrReview() ||
        permissionManagerReview()
      );
      allow delete: if isAuth() && isActive() && isHR();
    }

    match /advances/{advanceId} {
      allow read: if isAuth() && isActive() && (
        isOwner(resource.data.userId) ||
        isMyManager(resource.data.managerId) ||
        isHR()
      );
      allow create: if isAuth() && isActive()
        && isValidSelfCreate()
        && request.resource.data.status == 'pending_hr'
        && request.resource.data.amount > 0
        && request.resource.data.keys().hasOnly([
          'userId', 'employeeId', 'employeeName', 'department', 'locationId',
          'managerId', 'amount', 'reason', 'status', 'monthKey', 'submittedAt',
          'isRead', 'managerIds', 'managerNames', 'managerApprovalIndex',
          'managerApprovalTotal', 'managerApprovalTrail'
        ]);
      allow update: if isAuth() && isActive() && (
        (
          isOwner(resource.data.userId)
          && resource.data.status == 'pending_hr'
          && request.resource.data.status == 'cancelled'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        ) ||
        advanceHrReview() ||
        advanceManagerReview() ||
        isSuperAdmin()
      );
      allow delete: if isAuth() && isActive() && isHR();
    }

    match /suggestions/{suggestionId} {
      allow read: if isAuth() && isActive() && (
        isOwner(resource.data.userId) || canReviewSuggestions()
      );
      allow create: if isAuth() && isActive()
        && request.resource.data.userId == uid()
        && request.resource.data.employeeId == userDoc().get('employeeId', '')
        && request.resource.data.employeeName == userDoc().get('displayName', '')
        && request.resource.data.department == userDoc().get('department', '')
        && request.resource.data.status == 'new'
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 3
        && request.resource.data.body is string
        && request.resource.data.body.size() >= 10
        && request.resource.data.keys().hasOnly([
          'userId', 'employeeId', 'employeeName', 'department',
          'title', 'body', 'status', 'submittedAt'
        ]);
      allow update: if isAuth() && isActive() && canReviewSuggestions()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'reviewedBy', 'reviewedAt'])
        && request.resource.data.status == 'reviewed'
        && request.resource.data.reviewedBy == uid();
      allow delete: if isAuth() && isActive() && isSuperAdmin();
    }

    match /complaints/{complaintId} {
      allow read: if isAuth() && isActive() && (
        isOwner(resource.data.userId) || isHR()
      );
      allow create: if isAuth() && isActive()
        && request.resource.data.userId == uid()
        && request.resource.data.employeeId == userDoc().get('employeeId', '')
        && request.resource.data.employeeName == userDoc().get('displayName', '')
        && request.resource.data.department == userDoc().get('department', '')
        && request.resource.data.status == 'new'
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 3
        && request.resource.data.body is string
        && request.resource.data.body.size() >= 10
        && request.resource.data.get('attachmentUrl', '') is string
        && request.resource.data.keys().hasOnly([
          'userId', 'employeeId', 'employeeName', 'department',
          'title', 'body', 'attachmentUrl', 'status', 'submittedAt'
        ]);
      allow update: if isAuth() && isActive() && isHR()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'reviewedBy', 'reviewedAt'])
        && request.resource.data.status in ['reviewed', 'closed']
        && request.resource.data.reviewedBy == uid();
      allow delete: if isAuth() && isActive() && isSuperAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAuth() && isActive() && (
        isOwner(resource.data.assigneeId) ||
        isMyManager(resource.data.managerId) ||
        uid() in resource.data.get('managerIds', []) ||
        isHR()
      );
      allow create: if isAuth() && isActive()
        && taskCreateKeys()
        && taskCreateValues();
      allow update: if isAuth() && isActive() && (
        taskOwnerStatusUpdate() ||
        taskReviewerUpdate() ||
        isSuperAdmin()
      );
      allow delete: if isAuth() && isActive() && isSuperAdmin();
    }

    match /kpiTemplates/{templateId} {
      allow read: if isAuth() && isActive();
      allow create: if isAuth() && isActive()
        && isManagerOrAbove()
        && kpiTemplateCreateKeys()
        && request.resource.data.createdBy == uid()
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 3
        && request.resource.data.department is string
        && request.resource.data.department.size() > 0
        && request.resource.data.isActive == true;
      allow update: if isAuth() && isActive() && isHR();
      allow delete: if isAuth() && isActive() && isSuperAdmin();
    }

    match /employeeKpis/{employeeKpiId} {
      allow read: if isAuth() && isActive() && (
        isOwner(resource.data.userId) ||
        isMyManager(resource.data.managerId) ||
        uid() in resource.data.get('managerIds', []) ||
        isHR()
      );
      allow create: if isAuth() && isActive()
        && employeeKpiCreateKeys()
        && employeeKpiCreateValues();
      allow update: if isAuth() && isActive() && (
        employeeKpiProgressUpdate() ||
        isSuperAdmin()
      );
      allow delete: if isAuth() && isActive() && isSuperAdmin();
    }

    match /productivityScores/{scoreId} {
      allow read: if isAuth() && isActive() && (
        isOwner(resource.data.userId) ||
        isMyManager(resource.data.managerId) ||
        isHR()
      );
      allow create, update: if isAuth() && isActive()
        && productivityScoreKeys()
        && productivityScoreValues();
      allow delete: if isAuth() && isActive() && isSuperAdmin();
    }

    match /warningsRewards/{recordId} {
      allow read: if isAuth() && isActive() && (
        isOwner(resource.data.userId) ||
        isMyManager(resource.data.managerId) ||
        isHR()
      );
      allow create: if isAuth() && isActive()
        && warningRewardKeys()
        && warningRewardCreateValues();
      allow update: if isAuth() && isActive() && (
        warningRewardManagerUpdate() ||
        warningRewardOwnerAcknowledge() ||
        isSuperAdmin()
      );
      allow delete: if isAuth() && isActive() && isSuperAdmin();
    }

    match /payrollRuns/{payrollId} {
      allow read: if isAuth() && isActive() && (
        isOwner(resource.data.userId) || isHR()
      );
      allow create, update: if isAuth() && isActive() && isHR()
        && payrollRunKeys()
        && payrollRunValues();
      allow delete: if isAuth() && isActive() && isSuperAdmin();
    }

    match /performance/{performanceId} {
      allow read: if isAuth() && isActive() && (
        isOwner(resource.data.userId) ||
        isMyManager(resource.data.managerId) ||
        isHR()
      );
      allow create, update: if isAuth() && isActive()
        && (
          isHR() ||
          (isManagerRole() && request.resource.data.managerId == uid())
        );
      allow delete: if isAuth() && isActive() && isHR();
    }

    match /notifications/{userId}/items/{notificationId} {
      allow read: if isAuth() && isActive() && uid() == userId;
      allow create: if isAuth() && isActive()
        && notificationKeysAreValid()
        && canCreateNotificationFor(userId);
      allow update: if isAuth() && isActive() && uid() == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
        && request.resource.data.isRead is bool;
      allow delete: if isAuth() && isActive() && uid() == userId;
    }

    match /announcements/{announcementId} {
      allow read: if isAuth() && isActive();
      allow create, update, delete: if isAuth() && isActive() && isHR();
    }

    match /auditLogs/{auditId} {
      allow read: if isAuth() && isActive() && isHR();
      allow create: if isAuth() && isActive() && request.resource.data.actorId == uid();
      allow update, delete: if false;
    }
  }
}
